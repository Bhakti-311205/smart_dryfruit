# Server
PORT=8000
NODE_ENV=production

# JWT Secret (change this to a strong random string)
JWT_SECRET=your_jwt_secret_here

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_dryfruit

# Resend Email Service (for OTP emails)
# Sign up at https://resend.com to get a free API key (3,000 emails/month free)
RESEND_API_KEY=re_your_api_key_here
# Use onboarding@resend.dev (no domain needed) OR your verified domain email
EMAIL_FROM=NutHub <onboarding@resend.dev>

# Razorpay Keys
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret
