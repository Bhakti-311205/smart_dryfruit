# Server
PORT=8000
NODE_ENV=production

# JWT Secret (change this to a strong random string)
JWT_SECRET=your_jwt_secret_here

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_dryfruit

# SendGrid Email Service
# Get a free API key at https://sendgrid.com
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
EMAIL_FROM=your_verified_sender_email@example.com

# Razorpay Keys
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_secret
